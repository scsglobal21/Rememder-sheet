// ✅ Due date varun 7, 3, 1 days before dates calculate
function calcReminderDates(dueDateStr) {
  if (!dueDateStr) return { day7: "", day3: "", day1: "" };
  var due = parseDateStr(dueDateStr);
  if (!due || isNaN(due.getTime())) return { day7: "", day3: "", day1: "" };
  var months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  function offsetDate(baseDate, offsetDays) {
    var d = new Date(baseDate.getTime());
    d.setDate(d.getDate() - offsetDays);
    return String(d.getDate()).padStart(2,"0") + "-" + months[d.getMonth()] + "-" + d.getFullYear();
  }
  return {
    day7: offsetDate(due, 7),
    day3: offsetDate(due, 3),
    day1: offsetDate(due, 1)
  };
}

// ✅ Sheet row madhe dates write karo
function fillReminderDates(row) {
  var sheet  = getSheet();
  var values = sheet.getRange(row, 1, 1, 13).getValues()[0];
  var d      = parseRow(values);
  var type   = (d.type || "").toLowerCase();
  var dueStr = (type === "service") ? d.serviceDue : d.paymentDue;
  var dates  = calcReminderDates(dueStr);
  if (dates.day7) {
    sheet.getRange(row, 10).setValue(dates.day7);
    sheet.getRange(row, 11).setValue(dates.day3);
    sheet.getRange(row, 12).setValue(dates.day1);
    Logger.log("📅 Dates filled row " + row + ": " + JSON.stringify(dates));
  }
}

