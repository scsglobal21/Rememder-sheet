// ✅ Triggers Setup
function setupTrigger() {
  var triggers = ScriptApp.getProjectTriggers();
  for (var i = 0; i < triggers.length; i++) {
    ScriptApp.deleteTrigger(triggers[i]);
  }
  ScriptApp.newTrigger("dailyAutoSend")
    .timeBased()
    .everyDays(1)
    .atHour(9)
    .nearMinute(0)
    .create();
  ScriptApp.newTrigger("onEditTrigger")
    .forSpreadsheet(SpreadsheetApp.getActive())
    .onEdit()
    .create();
  Logger.log("✅ Triggers set! Daily 9AM + onEdit active.");
}

// ✅ onEdit — "Sending" set केल्यावर लगेच msg जाईल
function onEditTrigger(e) {
  var sheet = getSheet();
  var row   = e.range.getRow();
  var col   = e.range.getColumn();

  if (row < 2) return;

  // ✅ Status column नाही — फक्त dates fill
  if (col !== 13) {
    fillReminderDates(row);
    return;
  }

  // ✅ Status column edit झाला — "Sending" आहे का check करा
  var values = sheet.getRange(row, 1, 1, 13).getValues();
  if (!values || !values[0]) return;

  var d = parseRow(values[0]);

  // ✅ फक्त "Sending" असेल तरच msg पाठव
  if (d.status !== "Sending") return;
  if (!d.mobile || !d.name || !d.type) return;

  var today = getTodayString();
  var type  = (d.type || "").toLowerCase();
  var key   = getKey(type, d, today);
  if (!key) return;

  Logger.log("📤 Sending triggered: " + d.name + " | " + key);

  var ok = sendWhatsApp(d.mobile, TEMPLATES[key], getParams(d, key));
  if (ok) {
    sheet.getRange(row, 13).setValue("Sent");
    Logger.log("✅ Sent: " + d.name + " | " + key);
  } else {
    sheet.getRange(row, 13).setValue("Pending");
    Logger.log("❌ Failed — Pending: " + d.name);
  }
}

// ✅ Daily 9AM — Pending rows ला directly msg पाठवेल
function dailyAutoSend() {
  var sheet   = getSheet();
  var today   = getTodayString();
  var allData = sheet.getDataRange().getValues();
  var sent    = 0;

  Logger.log("🔄 Daily Auto check: " + today);

  for (var i = 1; i < allData.length; i++) {
    if (!allData[i] || allData[i].length < 13) continue;
    var d    = parseRow(allData[i]);
    var type = (d.type || "").toLowerCase();

    if (!d.mobile) continue;

    // ✅ फक्त "Pending" rows
    if (d.status !== "Pending") continue;

    var key = getKey(type, d, today);
    if (!key) continue;

    // ✅ Duplicate block — आधी Sending set करा
    sheet.getRange(i + 1, 13).setValue("Sending");
    SpreadsheetApp.flush();

    // ✅ Directly msg पाठवा
    var ok = sendWhatsApp(d.mobile, TEMPLATES[key], getParams(d, key));
    if (ok) {
      sheet.getRange(i + 1, 13).setValue("Sent");
      sent++;
      Logger.log("✅ Sent: " + d.name + " | " + key);
    } else {
      sheet.getRange(i + 1, 13).setValue("Pending");
      Logger.log("❌ Failed: " + d.name + " | " + key);
    }
  }
  Logger.log("✅ Daily done: " + today + " | Total Sent: " + sent);
}

// ✅ Key Logic
function getKey(type, d, today) {
  var key = null;
  if (type === "birthday") {
    if (matchDayMonth(d.birthday, today)) {
      key = "birthday";
      Logger.log("🎂 Birthday: " + d.name + " | " + d.birthday);
    }
  } else if (type === "anniversary") {
    if (matchDayMonth(d.anniversary, today)) {
      key = "anniversary";
      Logger.log("💍 Anniversary: " + d.name + " | " + d.anniversary);
    }
  } else if (type === "service" && d.serviceDue) {
    var due = parseDateStr(d.serviceDue);
    if (due) {
      var diff = daysDiff(today, due);
      if      (diff === 7) { key = "service_7";  Logger.log("🔧 Service 7d: " + d.name); }
      else if (diff === 3) { key = "service_3";  Logger.log("🔧 Service 3d: " + d.name); }
      else if (diff === 1) { key = "service_1";  Logger.log("🔧 Service 1d: " + d.name); }
    }
  } else if (type === "payment" && d.paymentDue) {
    var due2 = parseDateStr(d.paymentDue);
    if (due2) {
      var diff2 = daysDiff(today, due2);
      if      (diff2 === 7) { key = "payment_7"; Logger.log("💰 Payment 7d: " + d.name); }
      else if (diff2 === 3) { key = "payment_3"; Logger.log("💰 Payment 3d: " + d.name); }
      else if (diff2 === 1) { key = "payment_1"; Logger.log("💰 Payment 1d: " + d.name); }
    }
  }
  return key;
}

// ✅ Manual Send — Selected Row
function manualSendRow() {
  var sheet = getSheet();
  var ui    = SpreadsheetApp.getUi();
  var row   = sheet.getActiveCell().getRow();
  if (row < 2) { ui.alert("Customer row var click kara."); return; }
  var values = sheet.getRange(row, 1, 1, 13).getValues();
  if (!values || !values[0]) { ui.alert("Row data nahi."); return; }
  var d = parseRow(values[0]);
  if (!d.mobile) { ui.alert("Mobile number nahi."); return; }

  var today = getTodayString();
  var type  = (d.type || "").toLowerCase();
  var key   = null;

  if      (type === "birthday")    { key = "birthday"; }
  else if (type === "anniversary") { key = "anniversary"; }
  else if (type === "service") {
    if      (d.day1 === today) key = "service_1";
    else if (d.day3 === today) key = "service_3";
    else                       key = "service_7";
  } else if (type === "payment") {
    if      (d.day1 === today) key = "payment_1";
    else if (d.day3 === today) key = "payment_3";
    else                       key = "payment_7";
  }

  if (!key) { ui.alert("Template match nahi zhala."); return; }

  var resp = ui.alert(
    "Send Message?",
    d.name + " (" + d.type + ")\nTemplate: " + TEMPLATES[key],
    ui.ButtonSet.YES_NO
  );
  if (resp !== ui.Button.YES) return;

  var ok = sendWhatsApp(d.mobile, TEMPLATES[key], getParams(d, key));
  if (ok) {
    sheet.getRange(row, 13).setValue("Sent");
    ui.alert("✅ Sent to " + d.name);
  } else {
    ui.alert("❌ Failed. Check Execution log.");
  }
}

