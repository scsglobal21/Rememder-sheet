// ✅ WhatsApp API Call
function sendWhatsApp(mobile, templateName, params) {
  try {
    var mob = String(mobile).replace(/\D/g, "");
    if (mob.length === 10) mob = "91" + mob;
    if (mob.indexOf("91") !== 0) mob = "91" + mob;
    if (mob.length !== 12) { Logger.log("Invalid mobile: " + mobile); return false; }

    var parameters = [];
    for (var i = 0; i < params.length; i++) {
      parameters.push({ type: "text", text: String(params[i]) });
    }

    var payload = {
      to:             mob,
      recipient_type: "individual",
      type:           "template",
      template: {
        language:   { policy: "deterministic", code: "en" },
        name:       templateName,
        components: [{ type: "body", parameters: parameters }]
      }
    };

    var options = {
      method:             "post",
      contentType:        "application/json",
      headers:            { "Authorization": "Bearer " + TOKEN },
      payload:            JSON.stringify(payload),
      muteHttpExceptions: true
    };

    var response = UrlFetchApp.fetch(API_URL, options);
    var code     = response.getResponseCode();
    var body     = response.getContentText();
    Logger.log("To: " + mob + " | Template: " + templateName + " | Status: " + code + " | " + body);
    return (code === 200 || code === 201);
  } catch (e) {
    Logger.log("Error: " + e.message);
    return false;
  }
}

// ✅ Helper Functions
function getSheet() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  return ss.getSheetByName(SHEET_NAME) || ss.getActiveSheet();
}

function toStr(v) {
  if (v === null || v === undefined || v === "") return "";
  if (v instanceof Date) {
    var dd = String(v.getDate()).padStart(2, "0");
    var mm = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"][v.getMonth()];
    return dd + "-" + mm + "-" + v.getFullYear();
  }
  return String(v).trim();
}

function parseRow(r) {
  if (!r) return {};
  return {
    id:          toStr(r[0]),
    name:        toStr(r[1]),
    mobile:      toStr(r[2]),
    type:        toStr(r[3]),
    birthday:    toStr(r[4]),
    anniversary: toStr(r[5]),
    serviceDue:  toStr(r[6]),
    paymentDue:  toStr(r[7]),
    amount:      toStr(r[8]),
    day7:        toStr(r[9]),
    day3:        toStr(r[10]),
    day1:        toStr(r[11]),
    status:      toStr(r[12])
  };
}

function getTodayString() {
  var now    = new Date();
  var dd     = String(now.getDate()).padStart(2, "0");
  var months = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
  return dd + "-" + months[now.getMonth()] + "-" + now.getFullYear();
}

function matchDayMonth(dateStr, today) {
  if (!dateStr) return false;
  var dp = dateStr.split("-");
  var tp = today.split("-");
  if (dp.length < 2 || tp.length < 2) return false;
  var match = (dp[0] === tp[0] && dp[1] === tp[1]);
  Logger.log("📅 matchDayMonth | input: " + dateStr + " | today: " + today + " | result: " + match);
  return match;
}

function parseDateStr(val) {
  if (!val) return null;
  if (val instanceof Date) return val;
  var months = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
  var parts  = String(val).split("-");
  if (parts.length === 3) {
    var m = months[parts[1]];
    if (m !== undefined) {
      return new Date(parseInt(parts[2]), m, parseInt(parts[0]));
    }
  }
  return new Date(val);
}

function daysDiff(todayStr, dueDate) {
  var parts     = todayStr.split("-");
  var months    = {Jan:0,Feb:1,Mar:2,Apr:3,May:4,Jun:5,Jul:6,Aug:7,Sep:8,Oct:9,Nov:10,Dec:11};
  var todayDate = new Date(parseInt(parts[2]), months[parts[1]], parseInt(parts[0]));
  var diff      = Math.round((dueDate - todayDate) / (1000 * 60 * 60 * 24));
  return diff;
}
